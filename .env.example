# ── Required ─────────────────────────────────────────────────────────────────
# Path to your Ascent .db file (the one from ~/Library/Application Support/Ascent/)
ASCENT_DB_PATH=/path/to/your/ascent.db

# ── Strava Sync (optional) ────────────────────────────────────────────────────
# Get these from https://www.strava.com/settings/api
# Set the "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=174788
STRAVA_CLIENT_SECRET=your_client_secret_here

# Override if running behind a proxy (default: http://127.0.0.1:8000/strava/callback)
# STRAVA_REDIRECT_URI=http://127.0.0.1:8000/strava/callback
